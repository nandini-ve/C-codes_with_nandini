#include <stdio.h>
#include <limits.h>

int reverse(int x) {
    int r = 0;
    while (x != 0) {
        int digit = x % 10;
        x = x / 10;

        // Overflow check
        if (r > INT_MAX / 10 || (r == INT_MAX / 10 && digit > 7)) return 0;
        if (r < INT_MIN / 10 || (r == INT_MIN / 10 && digit < -8)) return 0;

        r = r * 10 + digit;
    }
    return r;
}

int main() {
    printf("%d\n", reverse(123));   // Output: 321
    printf("%d\n", reverse(-123));  // Output: -321
    printf("%d\n", reverse(120));   // Output: 21
    return 0;
}
