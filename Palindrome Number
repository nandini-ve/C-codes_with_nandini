#include <stdio.h>
#include <stdbool.h>

bool isPalindrome(int x) {
    if (x < 0) {
        return false;   // negative numbers are not palindromes
    }

    int r = 0, original = x;
    while (x != 0) {
        int digit = x % 10;   // take last digit
        x = x / 10;           // remove last digit
        r = r * 10 + digit;   // build reversed number
    }

    return (r == original);   // compare reversed with original
}

int main() {
    printf("%d\n", isPalindrome(121));   // Output: 1 (true)
    printf("%d\n", isPalindrome(-121));  // Output: 0 (false)
    printf("%d\n", isPalindrome(10));    // Output: 0 (false)
    return 0;
}
