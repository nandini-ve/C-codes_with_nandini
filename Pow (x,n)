#include <stdio.h>

double myPow(double x, int n) {
    long long exp = n;  // use long long to safely handle -2^31
    if (exp < 0) {
        x = 1 / x;      // reciprocal for negative exponent
        exp = -exp;
    }
    
    double result = 1.0;
    double current = x;
    
    while (exp > 0) {
        if (exp % 2 == 1) {   // if exponent is odd
            result *= current;
        }
        current *= current;   // square the base
        exp /= 2;             // halve the exponent
    }
    
    return result;
}

int main() {
    printf("%f\n", myPow(2.0, 10));   // 1024.000000
    printf("%f\n", myPow(2.1, 3));    // 9.261000
    printf("%f\n", myPow(2.0, -2));   // 0.250000
    return 0;
}
